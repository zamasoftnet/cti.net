{
  "metadata": [
    {
      "src": [
        {
          "files": ["CTI/CTI/*.csproj"]
        }
      ],
      "dest": "api",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["*.md"]
      }
    ],
    "resource": [],
    "dest": "build/apidoc",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": ["default"],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}
